# Theme (try: ghostty +list-themes to see all options)
theme = catppuccin-mocha

# Font
font-family = JetBrains Mono
font-size = 14

# Window
window-padding-x = 12
window-padding-y = 8
window-decoration = true
macos-titlebar-style = tabs

# Cursor
cursor-style = bar
cursor-style-blink = false

# Shell integration (enables marks, completions, etc.)
shell-integration = zsh
