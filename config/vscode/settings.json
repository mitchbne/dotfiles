{
  /**
   * Better Defaults
   **/
  "editor.copyWithSyntaxHighlighting": false,
  "editor.emptySelectionClipboard": false,
  "window.newWindowDimensions": "inherit",
  "files.trimTrailingWhitespace": true,
  "editor.snippetSuggestions": "top",
  "editor.detectIndentation": false,
  "window.nativeFullScreen": false,
  "files.insertFinalNewline": true,
  "files.trimFinalNewlines": true,
  "workbench.statusBar.visible": false,
  "editor.minimap.enabled": false,
  "workbench.editor.showTabs": "single",
  // "workbench.editor.showTabs": false,
  "editor.lineNumbers": "on",
  // "editor.lineNumbers": "off",
  /**
   * Silence The Noise
   */
  "zenMode.centerLayout": false,
  "zenMode.hideLineNumbers": false,
  "breadcrumbs.enabled": true,
  "scm.diffDecorations": "none",
  "editor.hover.enabled": "on",
  "editor.matchBrackets": "never",
  "workbench.tips.enabled": false,
  "editor.colorDecorators": false,
  // "git.decorations.enabled": false,
  "workbench.startupEditor": "none",
  "editor.lightbulb.enabled": "off",
  "editor.selectionHighlight": false,
  "editor.overviewRulerBorder": false,
  "editor.renderLineHighlight": "none",
  "editor.occurrencesHighlight": "off",
  "problems.decorations.enabled": false,
  "editor.renderControlCharacters": false,
  "editor.hideCursorInOverviewRuler": true,
  "editor.gotoLocation.multipleReferences": "goto",
  "editor.gotoLocation.multipleDefinitions": "goto",
  "editor.gotoLocation.multipleDeclarations": "goto",
  "workbench.editor.enablePreviewFromQuickOpen": false,
  "editor.gotoLocation.multipleImplementations": "goto",
  "editor.gotoLocation.multipleTypeDefinitions": "goto",
  "editor.fontFamily": "'MonoLisa'",
  "editor.fontSize": 15,
  "editor.lineHeight": 25,
  "editor.suggestFontSize": 15,
  "editor.suggestLineHeight": 28,
  "terminal.integrated.fontSize": 15,
  "terminal.integrated.lineHeight": 1.5,
  "terminal.integrated.gpuAcceleration": "off",
  /**
   * Search
   **/
  "search.useIgnoreFiles": false,
  "search.exclude": {
    // Hide everything in /vendor, except the "laravel" and "livewire" folder.
    "**/vendor/{[^l],?[^ai]}*": true,
    // Hide everything in /public, except "index.php"
    "**/public/{[^i],?[^n]}*": true,
    "**/_ide_helper.php": true,
    "**/composer.lock": true,
    "storage": true,
    ".phpunit.result.cache": true,
    "**/dist": true,
    "**/.bundle": true,
    "**/package-lock.json": true,
    "**/yarn.lock": true,
    "**/app/assets/webpack/helpers/routes.js.*": true,
    "**/*hot-update.js": true,
    "**/public/assets/webpack": true,
    "**/.cache/**": true,
    "**/.yarn/**": true,
    "**/.next/**": true,
    "**/tmp/*/**": true,
    "**/node_modules/*/**": true,
    "**/flow-typed/*/**": true,
    "**/__pycache__/*/**": true,
    "TAGS": true
  },
  "files.watcherExclude": {
    // Hide everything in /vendor, except the "laravel" and "livewire" folder.
    "**/vendor/{[^l],?[^ai]}*": true,
    // Hide everything in /public, except "index.php"
    "**/public/{[^i],?[^n]}*": true,
    "**/_ide_helper.php": true,
    "**/composer.lock": true,
    "storage": true,
    ".phpunit.result.cache": true,
    "**/dist": true,
    "**/.bundle": true,
    "**/package-lock.json": true,
    "**/yarn.lock": true,
    "**/app/assets/webpack/helpers/routes.js.*": true,
    "**/*hot-update.js": true,
    "**/public/assets/webpack": true,
    "**/.cache/**": true,
    "**/.yarn/**": true,
    "**/.next/**": true,
    "**/tmp/*/**": true,
    "**/node_modules/*/**": true,
    "**/flow-typed/*/**": true,
    "**/__pycache__/*/**": true,
    "TAGS": true
  },
  /**
   * Window Settings
   **/
  "window.customTitleBarVisibility": "auto",
  "window.titleBarStyle": "native",
  "window.nativeTabs": false,

  /**
    Hidden files
    **/
  "files.exclude": {
    "**/.git": true,
    "**/.svn": true,
    "**/.hg": true,
    "**/CVS": true,
    "**/.DS_Store": true,
    "**/*.pyc": {
      "when": "$(basename).py"
    },
    "**/__pycache__": true
  },
  /**
   * My own Settings.json
   **/
  "workbench.iconTheme": "material-icon-theme",
  "editor.tabSize": 2, // Use two spaces foreach tab ->
  "editor.renderWhitespace": "all", // Show whitespace as dots
  // "editor.renderWhitespace": "all", // Show whitespace as dots
  "javascript.validate.enable": false,
  "typescript.validate.enable": true,
  "scss.validate": false,
  "less.validate": false,
  "javascript.updateImportsOnFileMove.enabled": "always",
  "explorer.confirmDragAndDrop": false,
  "better-comments.highlightPlainText": true,
  "git.enableSmartCommit": true,
  "git.autofetch": true,
  "explorer.confirmDelete": false,
  "eslint.validate": [
    "javascript",
    "javascriptreact",
    "typescriptreact"
  ],
  "git.confirmSync": false,
  "editor.fontLigatures": "'calt' on, 'liga' on, 'zero' on, 'ss02' off",
  "explorer.decorations.badges": false,
  "tailwindCSS.emmetCompletions": true,
  "files.associations": {
    "*.js": "javascript",
    "*.html.erb": "erb"
  },
  "tailwindCSS.colorDecorators": true,
  "prettier.requireConfig": true,
  "prettier.useEditorConfig": false,
  "[typescript]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode",
    "editor.codeActionsOnSave": {
      "editor.formatOnSave": "explicit",
      "source.fixAll.eslint": "explicit"
    }
  },
  "[javascript]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode",
    "editor.formatOnSave": true,
    "editor.codeActionsOnSave": {
      "source.fixAll.eslint": "explicit"
    }
  },
  "[typescriptreact]": {
    "editor.defaultFormatter": "vscode.typescript-language-features",
    "editor.formatOnSave": true,
    "editor.codeActionsOnSave": {
      "source.fixAll.eslint": "explicit"
    }
  },
  "[javascriptreact]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode",
    "editor.formatOnSave": true,
    "editor.codeActionsOnSave": {
      "source.fixAll.eslint": "explicit"
    }
  },
  "[graphql]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode",
    "editor.formatOnSave": true,
    "editor.codeActionsOnSave": {
      "source.fixAll.eslint": "explicit"
    }
  },
  "[ruby]": {
    "editor.formatOnSave": false,
    "editor.defaultFormatter": "Shopify.ruby-lsp", // Use the Ruby LSP as the default formatter
    "editor.tabSize": 2,
    "editor.insertSpaces": true,
    "editor.semanticHighlighting.enabled": true,
    "editor.formatOnType": false,
  },

  "[erb]": {
    "editor.defaultFormatter": "Shopify.ruby-lsp",
    "editor.formatOnSave": false
  },
  "css.validate": true,
  "prettier.enableDebugLogs": true,
  "togglequotes.chars": [
    "\"",
    "`",
    "'"
  ],
  "editor.formatOnPaste": false,
  /**
   * Global Prettier Configuration
   **/
  // "prettier.tabWidth": 2,
  // "prettier.useTabs": false,
  // "prettier.quoteProps": "as-needed",
  // "prettier.semi": false,
  // "prettier.arrowParens": "always",
  // "prettier.printWidth": 100,
  // "prettier.htmlWhitespaceSensitivity": "css",
  // "prettier.singleQuote": false,
  // "prettier.jsxSingleQuote": false,
  // "prettier.trailingComma": "es5",
  // "prettier.bracketSpacing": true,
  // "prettier.proseWrap": "preserve",
  // "prettier.bracketSameLine": false,
  // "prettier.ignorePath": ".prettierignore",
  // "prettier.documentSelectors": [
  //   "**/*.{ts,tsx,js,jsx}"
  // ],
  "editor.inlineSuggest.enabled": true,
  "github.copilot.enable": {
    "*": false
  },
  "security.workspace.trust.untrustedFiles": "open",
  "emmet.includeLanguages": {
    "javascript": "javascriptreact",
    "typescript": "javascriptreact",
    "erb": "html"
  },
  "redhat.telemetry.enabled": false,
  "diffEditor.ignoreTrimWhitespace": false,
  "gitlens.defaultDateFormat": null,
  "gitlens.defaultDateShortFormat": null,
  "gitlens.defaultTimeFormat": null,
  "terminal.integrated.enableMultiLinePasteWarning": "never",
  "editor.guides.indentation": false,
  "simple-project-switcher.projectDirectories": [
    "~/github.com/buildkite",
    "~/github.com/mitchbne",
    "~/github.com/works-on-my-machine",
    "~/github.com/brisruby",
    "~/github.com/vercel",
    "~/github.com/ruby",
    "~/github.com/rails",
    "~/github.com/nickattanda",
    "~/github.com/cressylongford",
  ],
  "workbench.sideBar.location": "right",
  "yaml.validate": false,
  "gitlens.advanced.blame.customArguments": [
    "--ignore-revs-file",
    ".git-blame-ignore-revs"
  ],
  "gitlens.showWhatsNewAfterUpgrades": false,
  "update.mode": "default",
  "gitlens.advanced.repositorySearchDepth": 100,
  "editor.suggest.showFiles": false,
  "update.showReleaseNotes": false,
  "rubyLsp.rubyVersionManager": {
    "identifier": "mise"
  },
  "rubyLsp.enabledFeatures": {
    "codeActions": true,
    "diagnostics": true,
    "documentHighlights": true,
    "documentLink": true,
    "documentSymbols": true,
    "foldingRanges": true,
    "formatting": true,
    "hover": true,
    "inlayHint": true,
    "onTypeFormatting": true,
    "selectionRanges": true,
    "semanticHighlighting": true,
    "completion": true,
    "codeLens": false
  },
  "rubyLsp.formatter": "none",
  "editor.formatOnType": false,
  "[html]": {
    "editor.defaultFormatter": "vscode.html-language-features"
  },
  "editor.accessibilitySupport": "off",
  "workbench.editor.empty.hint": "hidden",
  "workbench.activityBar.location": "hidden",
  "[graphql][javascript][javascriptreact][typescriptreact]": {
    "editor.codeActionsOnSave": {
      "source.fixAll.eslint": "explicit"
    }
  },
  "workbench.layoutControl.enabled": false,
  "window.commandCenter": false,
  "editor.stickyScroll.enabled": false,
  "prisma.showPrismaDataPlatformNotification": false,
  "github.copilot.editor.enableAutoCompletions": true,
  "[json]": {
    "editor.defaultFormatter": "vscode.json-language-features"
  },
  "explorer.confirmPasteNative": false,
  "zenMode.showTabs": "none",
  // Before
  // "terminal.external.osxExec": "Terminal.app"
  "terminal.external.osxExec": "Warp.app",
  "security.promptForLocalFileProtocolHandling": false,
  "typescript.inlayHints.enumMemberValues.enabled": true,
  "typescript.inlayHints.parameterTypes.enabled": true,
  "javascript.inlayHints.variableTypes.enabled": true,
  "javascript.inlayHints.propertyDeclarationTypes.enabled": true,
  "javascript.preferences.importModuleSpecifier": "non-relative",
  "erb.erb-lint.suppressERBLintWarnings": false,
  "screencastMode.fontSize": 24,
  "screencastMode.keyboardOptions": {
    "showSingleEditorCursorMoves": false,
    "showKeys": false
  },
  "typescript.suggest.paths": false,
  "javascript.suggest.paths": false,
  "github.copilot.nextEditSuggestions.enabled": false,
  "docker.extension.enableComposeLanguageServer": false,
  "workbench.secondarySideBar.defaultVisibility": "hidden",
  "[dockercompose]": {
    "editor.insertSpaces": true,
    "editor.tabSize": 2,
    "editor.autoIndent": "advanced",
    "editor.quickSuggestions": {
      "other": true,
      "comments": false,
      "strings": true
    },
    "editor.defaultFormatter": "redhat.vscode-yaml"
  },
  "[github-actions-workflow]": {
    "editor.defaultFormatter": "redhat.vscode-yaml"
  },
  "typescript.updateImportsOnFileMove.enabled": "always",
  "amp.url": "https://ampcode.com/",
  "editor.wordBasedSuggestions": "off",
  "workbench.editor.enablePreview": false,
  "workbench.editorAssociations": {
    "git-rebase-todo": "default"
  },
  "terminal.integrated.profiles.osx": {
    "zsh (login)": {
      "path": "zsh",
      "args": [
        "-l",
        "-i"
      ]
    }
  },
  "terminal.integrated.defaultProfile.osx": "zsh (login)",
  "workbench.colorTheme": "Palenight (Mild Contrast)",
  "tailwindCSS.experimental.classRegex": [],
  "window.autoDetectColorScheme": true,
  "workbench.preferredDarkColorTheme": "Palenight (Mild Contrast)"
}
